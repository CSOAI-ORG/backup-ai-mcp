{
  "name": "backup-ai-mcp",
  "description": "Backup Ai automation via MCP. Includes create backup plan, verify backup, list backups. By MEOK AI Labs.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "create_backup_plan",
      "description": "MEOK AI Labs tool.",
      "parameters": {
        "type": "object",
        "properties": {
          "source_path": {
            "type": "string"
          },
          "destination": {
            "type": "string"
          },
          "frequency": {
            "type": "string"
          }
        },
        "required": [
          "source_path"
        ]
      }
    },
    {
      "name": "verify_backup",
      "description": "MEOK AI Labs tool.",
      "parameters": {
        "type": "object",
        "properties": {
          "backup_path": {
            "type": "string"
          }
        },
        "required": [
          "backup_path"
        ]
      }
    },
    {
      "name": "list_backups",
      "description": "MEOK AI Labs tool.",
      "parameters": {
        "type": "object",
        "properties": {
          "directory": {
            "type": "string"
          }
        },
        "required": []
      }
    },
    {
      "name": "calculate_backup_size",
      "description": "MEOK AI Labs tool.",
      "parameters": {
        "type": "object",
        "properties": {
          "source_path": {
            "type": "string"
          }
        },
        "required": [
          "source_path"
        ]
      }
    }
  ]
